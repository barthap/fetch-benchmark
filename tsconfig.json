{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": ["./*"],
      "expo-fetch-next": ["./modules/expo-fetch-next"],
      "expo-fetch-next/*": ["./modules/expo-fetch-next/*"]
    },
    "noUnusedLocals": false
  },
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts"]
}
